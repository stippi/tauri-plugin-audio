{
    "name": "tauri-plugin-audio-api",
    "version": "0.1.0",
    "author": "Affex Team",
    "description": "Native audio capture and playback API for Tauri with lock-free FFI audio paths",
    "license": "MIT",
    "keywords": [
        "tauri",
        "tauri-plugin",
        "audio",
        "capture",
        "playback",
        "native"
    ],
    "type": "module",
    "types": "./dist-js/index.d.ts",
    "main": "./dist-js/index.cjs",
    "module": "./dist-js/index.js",
    "exports": {
        "types": "./dist-js/index.d.ts",
        "import": "./dist-js/index.js",
        "require": "./dist-js/index.cjs"
    },
    "files": [
        "dist-js",
        "README.md"
    ],
    "scripts": {
        "build": "rollup -c",
        "prepublishOnly": "npm run build",
        "pretest": "npm run build"
    },
    "dependencies": {
        "@tauri-apps/api": "^2.9.1"
    },
    "devDependencies": {
        "@rollup/plugin-typescript": "^12.0.0",
        "rollup": "^4.55.1",
        "tslib": "^2.6.2",
        "typescript": "^5.3.3"
    }
}
